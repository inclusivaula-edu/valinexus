# =============================================================================
# VALINEXUS — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env no Git — apenas o .env.example vai para o repositório.
# =============================================================================

# ── Aplicação ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173
APP_URL=http://localhost:5173
LOG_LEVEL=info

# ── Banco de dados (PostgreSQL) ───────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=valinexus
DB_USER=postgres
DB_PASSWORD=postgres_dev_password
DB_POOL_MAX=20

# Em produção (Railway), use a connection string completa:
# DATABASE_URL=postgresql://user:password@host:5432/valinexus?sslmode=require

# ── Autenticação JWT ──────────────────────────────────────────────────────────
# Gere um segredo forte:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque_este_valor_por_algo_muito_secreto_em_producao
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── AWS S3 (upload de documentos) ────────────────────────────────────────────
AWS_REGION=sa-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=valinexus-docs

# ── WhatsApp (Evolution API) ─────────────────────────────────────────────────
# Evolution API é open-source: https://doc.evolution-api.com
# Alternativa hospedada: https://app.evolution-api.com
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=seu_api_key_aqui
EVOLUTION_INSTANCE=valinexus

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Dev: use Mailtrap (mailtrap.io) — captura emails sem enviar de verdade
# Prod: use AWS SES, SendGrid ou Brevo
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=seu_usuario_mailtrap
SMTP_PASS=sua_senha_mailtrap
SMTP_FROM_NAME=VALINEXUS Alertas
SMTP_FROM_EMAIL=alertas@valinexus.com.br

# ── Controle de notificações ──────────────────────────────────────────────────
# false em dev para não enviar spam; true em produção
NOTIFICATIONS_ENABLED=false

# ── Claude API (extração automática de documentos + agente regulatório) ───────
# Obtido em: https://console.anthropic.com/settings/keys
# Sem esta chave o upload funciona mas sem extração automática de dados.
ANTHROPIC_API_KEY=

# ── Agente Regulatório (opcional) ────────────────────────────────────────────
# URLs adicionais para monitorar além dos padrões (Petrobras CRC, MTE, RF).
# Formato: url::NomeLegível|url2::Nome2
# REGULATORY_URLS=https://minha-url.gov.br::Nome Portal
