# =============================================================================
# VALINEXUS — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env no Git — apenas o .env.example vai para o repositório.
# =============================================================================

# ── Aplicação ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=info

# ── Banco de dados (PostgreSQL) ───────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=valinexus
DB_USER=postgres
DB_PASSWORD=postgres_dev_password
DB_POOL_MAX=20

# Em produção (Railway/AWS RDS), use a connection string completa:
# DATABASE_URL=postgresql://user:password@host:5432/valinexus?sslmode=require

# ── Autenticação JWT ──────────────────────────────────────────────────────────
# Gere um segredo forte: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque_este_valor_por_algo_muito_secreto_em_producao
JWT_EXPIRES_IN=15m           # access token: curto prazo (15 minutos)
JWT_REFRESH_EXPIRES_IN=7d    # refresh token: longo prazo (7 dias)

# ── AWS S3 (upload de documentos) ────────────────────────────────────────────
AWS_REGION=sa-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=valinexus-docs

# ── WhatsApp (Evolution API) ─────────────────────────────────────────────────
# Para alertas de certidão via WhatsApp
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=valinexus

# ── Email (AWS SES) ───────────────────────────────────────────────────────────
FROM_EMAIL=noreply@valinexus.com.br
SUPPORT_EMAIL=suporte@valinexus.com.br

# ── Notificações WhatsApp (Evolution API) ─────────────────────────────────────
# Evolution API é open-source e roda no seu próprio servidor.
# Guia de instalação: https://doc.evolution-api.com
# Alternativa hospedada: https://app.evolution-api.com
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=seu_api_key_aqui
EVOLUTION_INSTANCE=valinexus

# ── Notificações Email (SMTP / Mailtrap para dev) ─────────────────────────────
# Dev: use Mailtrap (mailtrap.io) — captura emails sem enviar de verdade
# Prod: use AWS SES, SendGrid ou Brevo
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=seu_usuario_mailtrap
SMTP_PASS=sua_senha_mailtrap
SMTP_FROM_NAME=VALINEXUS Alertas
SMTP_FROM_EMAIL=alertas@valinexus.com.br

# ── Controle de notificações ──────────────────────────────────────────────────
# Desabilitar envios em desenvolvimento para não spam
NOTIFICATIONS_ENABLED=false
# URL base do sistema (para links nos emails)
APP_URL=http://localhost:5173
